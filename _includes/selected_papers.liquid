<div class="publications" id="selected-publications-list">
  {% bibliography --group_by none --query @*[selected=true]* %}
</div>
<script>
document.addEventListener('DOMContentLoaded', function() {
  var items = document.querySelectorAll('#selected-publications-list ol.bibliography > li');
  var total = items.length;
  items.forEach(function(li, i) { li.setAttribute('data-pub-number', total - i); });
});
</script>
